# ===== Database (RDS) =====
DATABASE_URL=postgresql://agilerush_admin:YOUR_RDS_PASSWORD@YOUR_RDS_ENDPOINT:5432/agilerush

# ===== JWT =====
JWT_SECRET_KEY=YOUR_GENERATED_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ===== CORS =====
CORS_ORIGINS=http://YOUR_AGILERUSH_IP

# ===== Frontend Build Args =====
VITE_API_URL=/api
VITE_WS_URL=ws://YOUR_AGILERUSH_IP

# ===== S3 File Storage =====
STORAGE_BACKEND=s3
AWS_S3_BUCKET=agilerush-uploads-YOUR_ACCOUNT_ID
AWS_REGION=us-east-1

# ===== Email (SES) =====
EMAIL_PROVIDER=ses
AWS_SES_REGION=us-east-1
FROM_EMAIL=your-verified-email@gmail.com

# ===== App =====
APP_URL=http://YOUR_AGILERUSH_IP
